{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Agent: run once",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": { "RUN_MODE": "once" }
    },
    {
      "name": "Agent: scheduled",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": { "RUN_MODE": "schedule" }
    }
  ]
}
