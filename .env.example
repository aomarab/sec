# ─── LLM backend ────────────────────────────────────────────────
# Provider: "anthropic" | "openai" | "azure" | "ollama"
LLM_PROVIDER=anthropic

# Anthropic Claude (default)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
# Adaptive thinking improves analysis quality; set to false for lower latency/cost
ANTHROPIC_THINKING=true

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama (used when LLM_PROVIDER=ollama) — local, no key needed
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=llama3.1

# ─── Agent input parameters (mirror the MS Threat Intel Briefing Agent) ──
# Number of vulnerabilities the agent researches for active threats
INSIGHTS_TO_RESEARCH=10
# How far back (days) the agent researches threats
LOOK_BACK_DAYS=7
# Geographical scope the agent considers (free text, e.g. "Global", "EMEA", "Middle East")
REGION=Global
# Sector/industry the agent focuses on (free text, e.g. "Finance", "Healthcare", "Technology")
INDUSTRY=Technology

# Optional: focus keywords for asset/exposure context (comma-separated)
# e.g. "Exchange,Fortinet,VMware,Citrix"
ASSET_KEYWORDS=

# ─── Optional API keys for richer data ──────────────────────────
# NVD works without a key but a key raises rate limits: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ─── Email delivery (SMTP) ──────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_TO=ciso@example.com
EMAIL_FROM=threat-intel-agent@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ─── Scheduling ─────────────────────────────────────────────────
# When RUN_MODE=schedule, the agent runs on this cron (UTC). Default: 07:00 daily.
RUN_MODE=once
SCHEDULE_CRON=0 7 * * *

# Agent loop safety limit
MAX_AGENT_STEPS=12
